# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Proveedores LLM (cadena de fallback: Groq → clave del usuario → Gemini → OpenRouter)
# Groq: gratis en https://console.groq.com (14.400 req/día, visión + Whisper)
GROQ_API_KEY=
# Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# OpenRouter: https://openrouter.ai/keys (con $10 únicos: 1.000 req/día en modelos :free)
OPENROUTER_API_KEY=

# Secreto para cifrar las claves BYOK de los usuarios (genera uno: openssl rand -hex 32)
LLM_KEY_SECRET=

# Telegram bot
TELEGRAM_BOT_TOKEN=
